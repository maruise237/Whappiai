# Dokploy env — Whappi + Evolution API
# Copy/paste into Dokploy environment variables.

NODE_ENV=production
PORT=3000
APP_URL=https://whappi.kamtech.online
FRONTEND_URL=https://whappi.kamtech.online
FRONTEND_DOMAIN=whappi.kamtech.online
NEXT_PUBLIC_API_URL=https://whappi.kamtech.online

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Security
SESSION_SECRET=change-me-long-random-secret
TOKEN_ENCRYPTION_KEY=64_hex_chars_here
ADMIN_DASHBOARD_PASSWORD=change-me
MASTER_ADMIN_EMAIL=maruise237@gmail.com
MASTER_API_KEY=change-me-long-random-key

# WhatsApp provider = Evolution API
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolutionapi.kamtech.online
EVOLUTION_API_KEY=replace-with-your-evolution-api-key
# Keep empty to reuse exact Whappi sessionId as Evolution instanceName
EVOLUTION_INSTANCE_PREFIX=
EVOLUTION_WEBHOOK_SECRET=change-me-shared-secret

# Optional but recommended
REDIS_URL=redis://redis:6379

# Cal.com / other existing integrations
CAL_CLIENT_ID=
CAL_CLIENT_SECRET=
CAL_REDIRECT_URI=
