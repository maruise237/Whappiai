# Whappi production environment template
# Safe for GitHub: placeholders only, no real secrets.
# Target architecture: Dokploy + Traefik + Evolution API.

# Core app
NODE_ENV=production
PORT=3000
APP_URL=https://whappi.example.com
FRONTEND_URL=https://whappi.example.com
FRONTEND_DOMAIN=whappi.example.com
NEXT_PUBLIC_API_URL=https://whappi.example.com
DATABASE_PATH=/app/data/whatsapp.db

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# Security
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace_with_64_hex_characters
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=replace_with_a_long_random_secret
ADMIN_DASHBOARD_PASSWORD=replace_with_admin_password
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_API_KEY=replace_with_long_random_api_key

# WhatsApp provider
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolutionapi.example.com
EVOLUTION_API_KEY=replace_with_evolution_api_key
# Leave empty to reuse the Whappi session ID as Evolution instance name
EVOLUTION_INSTANCE_PREFIX=
EVOLUTION_WEBHOOK_SECRET=replace_with_shared_webhook_secret

# Optional Redis cache / queue backend
# Leave EMPTY unless a real Redis service exists and is reachable from the container.
REDIS_URL=

# Optional Cal.com integration
CAL_CLIENT_ID=
CAL_CLIENT_SECRET=
CAL_REDIRECT_URI=

# Optional payments - MoneyFusion (actif)
# Obtenez MONEYFUSION_API_URL depuis votre dashboard MoneyFusion > API de paiement
# IMPORTANT: Votre IP serveur doit être whitelistée dans le dashboard MoneyFusion
MONEYFUSION_API_URL=
MONEYFUSION_WEBHOOK_URL=https://whappi.example.com/api/v1/payments/moneyfusion/webhook
